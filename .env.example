# Which LLM provider the provider layer selects: anthropic | openai | ollama
LLM_PROVIDER=anthropic

# Optional explicit model id; each provider has a sensible default if blank.
LLM_MODEL=

# Credentials — set the one matching LLM_PROVIDER.
# You can also set/save these from the in-app Settings modal (encrypted at rest).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Master key that encrypts saved provider API keys (./data/secrets.enc).
# Generate one with (no dependencies needed):
#   python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# If unset, the Settings feature is disabled and credentials come from the vars above.
ENCRYPTION_KEY=

# Ollama host (used when LLM_PROVIDER=ollama; compose sets this to the ollama service).
OLLAMA_HOST=http://localhost:11434

# Where truth.yaml and generated CVs are persisted.
DATA_DIR=./data
